local SHADE_STYLE = Enum.EasingStyle.Linear;
local SHADE_DIRECTION = Enum.EasingDirection.In;

------- [ functions ]

local Element = {};

function Element.new(Object)
    local ClassName = Object.ClassName;
    
    if (ClassName == "Frame" or ClassName == "ScrollingFrame" or ClassName == "TextButton") then
        Element[Object] = {"BackgroundTransparency", Object.BackgroundTransparency, "BackgroundColor3", Object.BackgroundColor3};
    elseif (ClassName == "TextLabel") then        
        Element[Object] = {"TextTransparency", Object.TextTransparency, "TextColor3", Object.TextColor3};
    elseif (ClassName == "UIStroke") then
        Element[Object] = {"Transparency", Object.Transparency, "Color", Object.Color};
    elseif (ClassName == "ImageLabel") then
        Element[Object] = {"ImageTransparency", Object.ImageTransparency, "ImageColor3", Object.ImageColor3};
    end
end

function Element.GetShade(Color)
    return Color3.new(
        math.clamp(Color.R * SHADE_RATIO, 0, 1),
        math.clamp(Color.G * SHADE_RATIO, 0, 1),
        math.clamp(Color.B * SHADE_RATIO, 0, 1)
    );
end

function Element.Fade(Object)
    MenuState = (not MenuState);

    for _, UIElement in Object:GetDescendants() do
        local ElementInfo = Element[UIElement];

        if (ElementInfo) then
            local Property = ElementInfo[1];
            TweenService.Create(TweenService, UIElement, TweenInfo.new(FADE_TIME, FADE_STYLE, FADE_DIRECTION), {
                [Property] = (MenuState and ElementInfo[2]) or 1;
            }):Play();
        end
    end
end

function Element.Hover(Object, State)
    local ElementInfo = Element[Object];
    
    if (not ElementInfo) then
        return;
    end
    
    TweenService.Create(TweenService, Object, TweenInfo.new(SHADE_TIME, SHADE_STYLE, SHADE_DIRECTION), {
        [ElementInfo[3]] = (State and Element.GetShade(ElementInfo[4])) or ElementInfo[4];
    }):Play();
end

function Element.AddHover(Object, Function)
    Signal.new(Object.MouseEnter:Connect(function()
        Element.Hover(Object, true);

        if (Function) then
            Function(true);
        end
    end));

    Signal.new(Object.MouseLeave:Connect(function()
        Element.Hover(Object, false);

        if (Function) then
            Function(false);
        end
    end));
end

local function CreateInstance(Class, Parent, Properties)
    local New = Instance.new(Class);

    for Index, Value in Properties do
        New[Index] = Value
    end
   
    Element.new(New);
    New.Parent = Parent;

    return New;
end

local function GetTimestamp()
    return os.date("%H:%M:%S");
end

