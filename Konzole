------- [ konzole functions and connections ]

function Konzole.GetLabel()
    if (#LabelPool >= 1) then
        return table.remove(LabelPool, 1);
    else
        return CreateInstance("TextLabel", ScrollingFrame, {
            TextWrapped = true,
            ZIndex = 3,
            BorderSizePixel = 0,
            TextSize = 16,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            FontFace = Nunito,
            TextColor3 = Color3.new(1, 1, 1),
            RichText = true,
            Size = UDim2.new(1, -12, 0, 40), -- -12 <-- Padding overflow prevention
        });
    end
end

function Konzole.Print(...)
    local String = "";

    for _, Value in {...} do
        if (FilterTostring and (type(Value) == "table" or type(Value) == "userdata")) then
            local Metatable = getrawmetatable(Value);
            if (Metatable and Metatable.__tostring) then
                String ..= "[__tostring detected] ";
                continue;
            end
        end

        String = string.format(String.."%* ", Value);
    end

    local Label = Konzole.GetLabel();
    Label.Text = `{Timestamps and "<b>"..GetTimestamp().."</b>\t" or ""}{String}`
    Label.Size = UDim2.fromOffset(Label.AbsoluteSize.X, Label.TextBounds.Y);
    Label.Parent = ScrollingFrame;

    if (AutoScrolling) then
        ScrollingFrame.CanvasPosition = Vector2.new(0, ScrollingFrame.AbsoluteCanvasSize.Y - ScrollingFrame.AbsoluteWindowSize.Y);
    end
end

function Konzole.Printp(Prefix, ...)
    local String = "";

    for _, Value in {...} do
        if (FilterTostring and (type(Value) == "table" or type(Value) == "userdata")) then
            local Metatable = getrawmetatable(Value);
            if (Metatable and Metatable.__tostring) then
                String ..= "[__tostring detected] ";
                continue;
            end
        end

        String = string.format(String.."%* ", Value);
    end

    local Label = Konzole.GetLabel();
    Label.Text = `{Timestamps and GetTimestamp().."\t" or ""}<b><font color="#85FF00"> {Prefix}: </font></b>{String}`
    Label.Size = UDim2.fromOffset(Label.AbsoluteSize.X, Label.TextBounds.Y);
    Label.Parent = ScrollingFrame;

    if (AutoScrolling) then
        ScrollingFrame.CanvasPosition = Vector2.new(0, ScrollingFrame.AbsoluteCanvasSize.Y - ScrollingFrame.AbsoluteWindowSize.Y);
    end
end

function Konzole.Clear()
    for _, Object in ScrollingFrame:GetChildren() do
        if (Object.ClassName == "TextLabel") then
            Object.Parent = LabelsFolder;
            table.insert(LabelPool, Object);
        end
    end
end

