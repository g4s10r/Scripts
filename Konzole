------- [ signal ]

local Signal = {
	Cache = {};
};

function Signal.new(Connection)
	assert(Connection ~= nil, "Signal.new missing argument");
    assert(typeof(Connection) == "RBXScriptConnection", "Signal.new requires a valid RBXScriptConnection");

	Signal.Cache[Connection] = Connection;

	return setmetatable({
		Connection = Connection
	}, {__index = Signal});
end

function Signal.Shutdown()	
	for _, Connection in Signal.Cache do
		Connection:Disconnect();
	end
end

function Signal:Disconnect()
	assert(type(self) == "table", "Signal type mismatch");

	self.Connection:Disconnect();
	self.Cache[self.Connection] = nil;
end

